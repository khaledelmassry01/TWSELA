# ==============================================================
# Twsela Production Environment Variables
# Copy this file to .env and fill in the values
# ==============================================================

# --- Database ---
DB_PASSWORD=CHANGE_ME_strong_password_here
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password_here

# --- JWT ---
JWT_SECRET=CHANGE_ME_at_least_64_chars_base64_encoded_secret_key_here_1234567890

# --- CORS ---
CORS_ORIGINS=https://twsela.com,https://www.twsela.com

# --- Grafana (optional, for monitoring stack) ---
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# --- Twilio SMS (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
